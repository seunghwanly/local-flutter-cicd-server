# Flutter CI/CD Server - sample environment values
# Copy to .env and replace every placeholder before running the server.

WORKSPACE_ROOT=./.workspace
CACHE_CLEANUP_DAYS=7
MAX_PARALLEL_BUILDS=3

GITHUB_WEBHOOK_SECRET=replace_with_real_webhook_secret
REPO_URL=git@github.com:your_org/your_repo.git
GITHUB_TOKEN=replace_with_personal_access_token

FLUTTER_VERSION=stable

DEV_BRANCH_NAME=develop
DEV_FASTLANE_LANE=deploy_dev
WEBHOOK_DEV_BASE_BRANCH=develop
WEBHOOK_DEV_HEAD_PREFIX=release-dev-v

STAGE_BRANCH_NAME=staging
STAGE_FASTLANE_LANE=deploy_stage

PROD_BRANCH_NAME=main
PROD_FASTLANE_LANE=deploy_prod
WEBHOOK_PROD_TAG_PATTERN=^\d+\.\d+\.\d+$

SLACK_WEBHOOK_CHANNEL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

KEYCHAIN_NAME=login.keychain
KEYCHAIN_PASSWORD=replace_with_keychain_password
APPSTORE_API_KEY_ID=replace_with_appstore_key_id
APPSTORE_ISSUER_ID=replace_with_appstore_issuer_id
APPSTORE_API_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
replace_with_private_key_content
-----END PRIVATE KEY-----"

GOOGLE_SERVICE_ACCOUNT_JSON=replace_with_base64_encoded_service_account_json

COCOAPODS_VERSION=1.16.2
FASTLANE_VERSION=2.228.0
MATCH_PASSWORD=replace_with_match_password
FASTLANE_USER=replace_with_fastlane_user
FASTLANE_PASSWORD=replace_with_fastlane_password

LOG_LEVEL=INFO
DATADOG_API_KEY=replace_with_datadog_api_key
